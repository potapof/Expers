# ==========================================================================
# Переменные окружения для продакшен-деплоя на Yandex Cloud Serverless Container
# ==========================================================================
#
# Скопируйте этот файл и задайте реальные значения.
# Не коммитьте секреты (TBANK_PASSWORD, JWT_SECRET) в репозиторий.
# В Yandex Cloud переменные задаются через консоль или YC CLI.
# ==========================================================================

# Приложение
PORT=8080
NODE_ENV=production

# Yandex Cloud Document API (DynamoDB-совместимый)
DOCUMENT_API_ENDPOINT=https://docapi.serverless.yandexcloud.net/ru-central1/b1g.../etn...
DOCUMENT_API_REGION=ru-central1
AWS_ACCESS_KEY_ID=<your-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>
USE_DATABASE=true

# JWT — обязательно заменить dev-секрет на случайную строку (≥32 символов)
JWT_SECRET=<generate-with-openssl-rand-hex-32>

# ══════════════════════════════════════════════════════════════════════════
# T-Bank Acquiring (реальные платежи)
# ══════════════════════════════════════════════════════════════════════════
#
# НЕ задавайте TBANK_TEST_MODE — тестовый режим должен быть выключен.
# Ключи терминала и пароль → Личный кабинет Т-Банк Эквайринг →
#   Настройки → API-ключи.
# APP_BASE_URL — публичный HTTPS-адрес приложения. Т-Банк отправляет
#   webhook (POST /api/payments/webhook) именно на этот URL. Без HTTPS
#   webhook не дойдёт.
#
# IP Т-Банка для файрвола (опционально):
#   91.194.226.0/23, 91.218.132.0/23, 91.218.133.0/24, 91.218.134.0/24
# ==========================================================================

TBANK_TERMINAL_KEY=<your-terminal-key>
TBANK_PASSWORD=<your-terminal-password>
TBANK_API_URL=https://securepay.tinkoff.ru/v2
APP_BASE_URL=https://<your-domain>
