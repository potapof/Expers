{
  "name": "expers",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:docker": "next dev -p 8080",
    "build": "next build",
    "build:static": "npm run db:generate && cross-env OUTPUT_MODE=export next build",
    "start": "next start",
    "check": "npm run lint && npm run typecheck",
    "lint": "eslint .",
    "check:backlog": "tsx scripts/check-backlog.ts",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "db:migrate": "tsx scripts/migrate.ts",
    "docker:dev": "docker-compose up --build",
    "docker:dev:down": "docker-compose down",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "npx playwright test --grep smoke",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:reader": "npx playwright test e2e/reader.spec.ts",
    "test:e2e:author": "npx playwright test e2e/author.spec.ts",
    "test:e2e:admin": "npx playwright test e2e/admin.spec.ts",
    "test:e2e:api": "npx playwright test --project=api",
    "test:seed": "pwsh -File scripts/seed-test-data.ps1"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tailwindcss/postcss": "^4.2.2",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.10",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.2",
    "js-yaml": "^4.1.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.9"
  }
}
