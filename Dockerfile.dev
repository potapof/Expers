FROM node:24-alpine

RUN apk add --no-cache openssl ca-certificates

WORKDIR /app

# Install dependencies inside the image so native binaries match Alpine (musl).
# Host node_modules must NOT be mounted over this (see docker-compose anonymous volume).
COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts=false

EXPOSE 8080

CMD ["npm", "run", "dev:docker"]
